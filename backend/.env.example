# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080

# Auth
SESSION_SECRET=change-me-in-prod
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Azure APIM (read-only)
APIM_SUBSCRIPTION_ID=
APIM_RESOURCE_GROUP=
APIM_SERVICE_NAME=
# Optional: leave empty to use Azure Default Credentials
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Redis - one URL per context. Falls back to REDIS_URL when a context-specific
# URL is missing. Override at runtime via PUT /contexts/:id/endpoint.
REDIS_URL=redis://localhost:6379
REDIS_URL_DEV_CLOUD=
REDIS_URL_DEV_SELFHOST=
REDIS_URL_QA_CLOUD=
REDIS_URL_QA_SELFHOST=
REDIS_URL_PRE_CLOUD=
REDIS_URL_PRE_SELFHOST=
REDIS_URL_PRD_CLOUD=
REDIS_URL_PRD_SELFHOST=
